SUPERADMIN_EMAIL=evaristlukuba668@gmail.com
SUPERADMIN_PASSWORD=Phidtech@@2023
SUPERADMIN_NAME="Avid Finance Admin"

# Development Settings
TELESCOPE_ENABLED=false
HORIZON_ENABLED=false
DEBUGBAR_ENABLED=false