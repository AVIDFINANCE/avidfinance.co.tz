APP_NAME="Avid Finance - Microfinance System"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=https://avidfinance.co.tz
APP_VERSION=1.0.0

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=phidlms
DB_USERNAME=root
DB_PASSWORD=
MYSQL_ATTR_SSL_CA=

BROADCAST_DRIVER=pusher
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=240
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_HTTP_ONLY=true

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_APP_NAME="${APP_NAME}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# Beem SMS Configuration
BEEM_SMS_API_KEY=
BEEM_SMS_SECRET_KEY=
BEEM_SMS_SENDER_ID="PHIDLMS"
BEEM_SMS_BASE_URL="https://apisms.beem.africa/v1"

# Multi-tenancy Configuration
TENANT_MODEL=App\Models\Tenant
TENANT_DATABASE_CONNECTION_NAME=tenant

# Payment Gateway Configuration
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

# Selcom Payment Gateway Configuration
SELCOM_API_KEY=
SELCOM_API_SECRET=
SELCOM_MERCHANT_ID=
SELCOM_TILL_NUMBER=
SELCOM_BASE_URL=https://apigw.selcommobile.com
SELCOM_ENVIRONMENT=sandbox
SELCOM_ENABLED=false

# Search Configuration
SCOUT_DRIVER=meilisearch
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_KEY=

# File Storage Configuration
FILESYSTEM_DISK=local
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Application Specific Settings
DEFAULT_CURRENCY=TZS
DEFAULT_TIMEZONE=Africa/Dar_es_Salaam
DEFAULT_LANGUAGE=en

# Interest Calculation Settings
DEFAULT_INTEREST_RATE=15.0
DEFAULT_LOAN_TERM=12
DEFAULT_GRACE_PERIOD=7

# Notification Settings
NOTIFICATION_CHANNELS=database,mail,sms
SMS_ENABLED=true
EMAIL_ENABLED=true

# Backup Settings
BACKUP_DISK=local
BACKUP_RETENTION_DAYS=30

# Security Settings
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE_COOKIE=lax
SESSION_DOMAIN=
SESSION_LIFETIME=240
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,127.0.0.1,127.0.0.1:8000,::1,avidfinance.co.tz,www.avidfinance.co.tz

